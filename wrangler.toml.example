# Cloudflare Workers 配置模板
# 复制此文件为 wrangler.toml 并根据实际部署环境修改配置
# 注意：wrangler.toml 已在 .gitignore 中，不会被推送到仓库

# Worker 名称（根据实际部署环境修改）
name = "stevencress"
# 兼容性日期
compatibility_date = "2025-11-25"
# Worker 入口文件
main = "./src/index.ts"

# 环境变量（前端可通过 import.meta.env 访问）
[vars]
NODE_ENV = "production"
VITE_API_URL = "https://houduan-api.onrender.com"
VITE_Web_Trader_UUID = "c5e01236-d681-4343-8386-f9e17748f81f"

# 静态资源配置
[assets]
directory = "./dist/"
not_found_handling = "single-page-application"
binding = "ASSETS"
# 只有 API 请求先运行 Worker，其他请求直接由 Cloudflare 处理静态资源
run_worker_first = [ "/api/*" ]

# 路由配置（根据实际域名修改）
[[routes]]
pattern = "stevencress.com/*"
zone_name = "stevencress.com"

[[routes]]
pattern = "www.stevencress.com/*"
zone_name = "stevencress.com"

